# Copy this file to .env and fill in your own values.
# .env is gitignored — never commit real credentials.

# Plane API key / personal access token
# (Plane: Profile Settings > Personal Access Tokens)
PLANE_API_KEY=plane_api_xxxxxxxxxxxxxxxxxxxx

# Your Plane workspace slug (the app.plane.so/<slug>/... part of your URL)
PLANE_WORKSPACE_SLUG=your-workspace-slug

# Optional: API base URL. Defaults to Plane Cloud.
# Set this to your instance URL when self-hosting, e.g. https://plane.example.com
# PLANE_BASE_URL=https://api.plane.so

# Optional: tag every work item planestories creates with this label
# (auto-created). Off by default. Also settable per-run via --source-label.
# PLANE_SOURCE_LABEL=planestories

# Optional: retry budget for transient Plane API failures (HTTP 429, 5xx,
# network errors). Each retry uses Retry-After when present, else exponential
# backoff with jitter. Defaults to 5; set 0 to disable retries.
# PLANE_MAX_RETRIES=5
